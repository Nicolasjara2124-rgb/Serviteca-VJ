datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id           String   @id @default(uuid())
  code         String   @unique
  name         String
  brand        String
  model        String
  measure      String
  category     String
  cost         Float
  price        Float
  stock        Int      @default(0)
  minStock     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}